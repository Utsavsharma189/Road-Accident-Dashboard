    <worksheet name='FATAL CASUALITES BY ROAD SURFACE'>
      <table>
        <view>
          <datasources>
            <datasource caption='accident data' name='federated.1op9up300te5dy18oalgy0w7ehj9' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='current year' datatype='integer' datatype-customized='true' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='2022'>
              <calculation class='tableau' formula='2022' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1op9up300te5dy18oalgy0w7ehj9'>
            <column datatype='date' name='[Accident Date]' role='dimension' type='ordinal' />
            <column caption='Accident Severity' datatype='string' name='[Accident_Severity]' role='dimension' type='nominal' />
            <column caption='AVG(0)' datatype='real' name='[Calculation_826692032613302279]' role='measure' type='quantitative' user:unnamed='Sheet 15'>
              <calculation class='tableau' formula='AVG(0)' />
            </column>
            <column caption='AVG(0)' datatype='real' name='[Calculation_826692032613339145]' role='measure' type='quantitative' user:unnamed='Sheet 15'>
              <calculation class='tableau' formula='AVG(0)' />
            </column>
            <column caption='CURRENT YEAR CASUALITIES' datatype='integer' name='[Calculation_857935754264313856]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10; IF  YEAR([Accident Date]) = ([Parameters].[Parameter 1])THEN&#13;&#10;   [Number_of_Casualties]&#13;&#10;END&#13;&#10;)' />
            </column>
            <column caption='Number of Casualties' datatype='integer' name='[Number_of_Casualties]' role='measure' type='quantitative' />
            <column datatype='string' name='[Road Surface Conditions (group)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[Road_Surface_Conditions]' new-bin='true'>
                <bin default-name='false' value='&quot;Flood &quot;'>
                  <value>&quot;Flood over 3cm. deep&quot;</value>
                  <value>&quot;Wet or damp&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Frost &quot;'>
                  <value>&quot;Frost or ice&quot;</value>
                  <value>&quot;Snow&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Unknown&quot;'>
                  <value>%null%</value>
                  <value>&quot;Dry&quot;</value>
                </bin>
              </calculation>
            </column>
            <column caption='Road Surface Conditions' datatype='string' name='[Road_Surface_Conditions]' role='dimension' type='nominal' />
            <column-instance column='[Accident_Severity]' derivation='None' name='[none:Accident_Severity:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_826692032613302279]' derivation='User' name='[usr:Calculation_826692032613302279:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_826692032613339145]' derivation='User' name='[usr:Calculation_826692032613339145:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_857935754264313856]' derivation='User' name='[usr:Calculation_857935754264313856:qk]' pivot='key' type='quantitative' />
